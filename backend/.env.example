# Copy this file to .env and adjust as needed.
ENV=development

# Generate a strong random string for production, e.g.: openssl rand -hex 32
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=sqlite:///./data/paperpilot.db

MAX_UPLOAD_SIZE_MB=25

# All models below are free & open-source, pulled once from Hugging Face Hub
# and cached locally afterwards (no API key required).
SUMMARIZATION_MODEL=facebook/bart-large-cnn
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
QA_MODEL=deepset/roberta-base-squad2
SPACY_MODEL=en_core_web_sm

FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000
